    <Version>1.3</Version>
    <Description>Reminds you about retainer ventures.</Description>
    <PackageProjectUrl>https://github.com/Ibcrootbeer/RetainerAlerts</PackageProjectUrl>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
